#
# Test the faust-rs Cranelift JIT backend against the reference.
#
# Like the interpreter backend, `impulse_cranelift` reproduces only the scalar
# impulse pass (the first 15000 reference frames) and is compared with
# `filesCompare -part`. The backend runs in 64-bit (`-double`) so it can be
# compared directly against the `-double` reference.
#
# Run from this directory:  make -f Make.cranelift
#

include common.mk

outdir ?= cranelift

# Build everything except the documented known failures for this backend.
allnames  := $(dspfiles:dsp/%.dsp=%)
testnames := $(filter-out $(call known_fail_for,$(outdir)),$(allnames))
listfiles := $(testnames:%=ir/$(outdir)/%.ir)

.PHONY: all
.DELETE_ON_ERROR:

all: $(COMPARE) ir/$(outdir)/.dir $(listfiles)

ir/$(outdir)/.dir:
	mkdir -p ir/$(outdir)
	touch $@

$(COMPARE): tools/filesCompare.cpp
	$(CXX) -O2 -std=c++11 $< -o $@

ir/$(outdir)/%.ir: dsp/%.dsp reference/%.ir | ir/$(outdir)/.dir
	$(RUNNER_CRANELIFT) $< -double $(VECOPTS) -I dsp -n $(SCALARFRAMES) > $@ || (rm -f $@; false)
	$(COMPARE) $@ reference/$*.ir -part $(call dsp_precision,$*) || (rm -f $@; false)
