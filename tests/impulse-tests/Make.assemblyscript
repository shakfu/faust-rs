#
# Test the faust-rs AssemblyScript backend against the reference.
#
# `impulseasc.js` compiles the generated AssemblyScript through `asc`, runs the
# resulting WebAssembly module in Node, and reproduces the scalar impulse pass
# (the first 15000 reference frames). The result is compared with
# `filesCompare -part`.
#
# Run from this directory:  make -f Make.assemblyscript
#

include common.mk

outdir ?= assemblyscript
RUNNER_ASSEMBLYSCRIPT ?= node tools/impulseasc.js

# Build everything except the documented known failures for this backend.
allnames  := $(dspfiles:dsp/%.dsp=%)
testnames := $(filter-out $(call known_fail_for,$(outdir)),$(allnames))
listfiles := $(testnames:%=ir/$(outdir)/%.ir)

.PHONY: all
.DELETE_ON_ERROR:

all: $(COMPARE) ir/$(outdir)/.dir $(listfiles)

ir/$(outdir)/.dir:
	mkdir -p ir/$(outdir)
	touch $@

$(COMPARE): tools/filesCompare.cpp
	$(CXX) -O2 -std=c++11 $< -o $@

ir/$(outdir)/%.ir: dsp/%.dsp reference/%.ir | ir/$(outdir)/.dir
	FAUST_RS=$(FAUST_RS) $(RUNNER_ASSEMBLYSCRIPT) $< -double -I dsp -n $(SCALARFRAMES) > $@ || (rm -f $@; false)
	$(COMPARE) $@ reference/$*.ir -part $(call dsp_precision,$*) || (rm -f $@; false)
