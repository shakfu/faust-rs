digraph signal_schedule {
  rankdir=TB;
  node [fontname="Arial"];
  edge [fontname="Arial"];

  subgraph cluster_constants {
    label="Constant and Control Signals";
    style=filled;
    fillcolor=lightblue;
    fontsize=14;
  }

  subgraph cluster_audio {
    label="Audio Signals";
    style=filled;
    fillcolor=lightgreen;
    fontsize=14;
    node0 [label=<<font color="gray">0:</font> Input(1)> shape=ellipse fillcolor=yellow style=filled];
    node1 [label=<<font color="gray">1:</font> sigClocked(sample,...)> shape=box fillcolor=orange style=filled];
    node2 [label=<<font color="gray">2:</font> Input(0)> shape=ellipse fillcolor=yellow style=filled];
    node3 [label=<<font color="gray">3:</font> SigTempVar(...)> shape=ellipse fillcolor=white style=filled];
    node4 [label=<<font color="gray">4:</font> sigClocked(sample,...)> shape=box fillcolor=orange style=filled];
    node5 [label=<<font color="gray">5:</font> SigIntCast(...)> shape=ellipse fillcolor=white style=filled];
    node6 [label=<<font color="gray">6:</font> sigClocked(sample,...)> shape=box fillcolor=orange style=filled];
    node7 [label=<<font color="gray">7:</font> 0.5> shape=ellipse fillcolor=white style=filled];
    node8 [label=<<font color="gray">8:</font> sigClocked(0x135e19c70,...)> shape=box fillcolor=orange style=filled];
    node9 [label=<<font color="gray">9:</font> *(0.5, ...)> shape=ellipse fillcolor=white style=filled];
    node10 [label=<<font color="gray">10:</font> sigClocked(0x135e19c70,...)> shape=box fillcolor=orange style=filled];
    node11 [label=<<font color="gray">11:</font> SigPermVar(...)> shape=ellipse fillcolor=white style=filled];
    node12 [label=<<font color="gray">12:</font> SigOD(...)> shape=ellipse fillcolor=white style=filled];
    node13 [label=<<font color="gray">13:</font> SigSeq(...)> shape=ellipse fillcolor=white style=filled];
  }

  // Dependencies
  node1 -> node0;
  node3 -> node1;
  node4 -> node2;
  node5 -> node4;
  node6 -> node3;
  node8 -> node6;
  node9 -> node8;
  node10 -> node9;
  node11 -> node10;
  node12 -> node5;
  node13 -> node12;
  node13 -> node11;
}
