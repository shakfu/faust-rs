digraph signal_schedule {
  rankdir=TB;
  node [fontname="Arial"];
  edge [fontname="Arial"];

  subgraph cluster_constants {
    label="Constant and Control Signals";
    style=filled;
    fillcolor=lightblue;
    fontsize=14;
  }

  subgraph cluster_audio {
    label="Audio Signals";
    style=filled;
    fillcolor=lightgreen;
    fontsize=14;
    node0 [label=<<font color="gray">0:</font> Input(2)> shape=ellipse fillcolor=yellow style=filled];
    node1 [label=<<font color="gray">1:</font> Input(0)> shape=ellipse fillcolor=yellow style=filled];
    node2 [label=<<font color="gray">2:</font> sigClocked(sample,...)> shape=box fillcolor=orange style=filled];
    node3 [label=<<font color="gray">3:</font> sigClocked(sample,...)> shape=box fillcolor=orange style=filled];
    node4 [label=<<font color="gray">4:</font> 99> shape=ellipse fillcolor=white style=filled];
    node5 [label=<<font color="gray">5:</font> *(99, ...)> shape=ellipse fillcolor=white style=filled];
    node6 [label=<<font color="gray">6:</font> *(99, ...)> shape=ellipse fillcolor=white style=filled];
    node7 [label=<<font color="gray">7:</font> SigIntCast(...)> shape=ellipse fillcolor=white style=filled];
    node8 [label=<<font color="gray">8:</font> SigIntCast(...)> shape=ellipse fillcolor=white style=filled];
    node9 [label=<<font color="gray">9:</font> 99> shape=ellipse fillcolor=white style=filled];
    node10 [label=<<font color="gray">10:</font> sigClocked(sample,...)> shape=box fillcolor=orange style=filled];
    node11 [label=<<font color="gray">11:</font> sigClocked(sample,...)> shape=box fillcolor=orange style=filled];
    node12 [label=<<font color="gray">12:</font> min(99, ...)> shape=ellipse fillcolor=white style=filled];
    node13 [label=<<font color="gray">13:</font> min(99, ...)> shape=ellipse fillcolor=white style=filled];
    node14 [label=<<font color="gray">14:</font> Input(1)> shape=ellipse fillcolor=yellow style=filled];
    node15 [label=<<font color="gray">15:</font> 0> shape=ellipse fillcolor=white style=filled];
    node16 [label=<<font color="gray">16:</font> max(0, ...)> shape=ellipse fillcolor=white style=filled];
    node17 [label=<<font color="gray">17:</font> max(0, ...)> shape=ellipse fillcolor=white style=filled];
    node18 [label=<<font color="gray">18:</font> sigClocked(sample,...)> shape=box fillcolor=orange style=filled];
    node19 [label=<<font color="gray">19:</font> SigRDTbl(...)> shape=ellipse fillcolor=white style=filled];
  }

  // Dependencies
  node2 -> node0;
  node3 -> node1;
  node5 -> node2;
  node6 -> node3;
  node7 -> node5;
  node8 -> node6;
  node10 -> node7;
  node11 -> node8;
  node12 -> node10;
  node13 -> node11;
  node16 -> node12;
  node17 -> node13;
  node18 -> node14;
  node19 -> node16;
}
